{
  "name": "setlist-to-playlist",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter web run dev",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm --filter @repo/shared run build && pnpm --filter @repo/core run build && pnpm --filter api run build && pnpm --filter web exec tsc --noEmit",
    "test": "pnpm -r run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "cleanup:repo": "bash scripts/cleanup-repo.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
